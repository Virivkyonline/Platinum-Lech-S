  <script>
    const WORKER_URL = "https://balboa-proxy-worker.lechstav.workers.dev";

    const appState = {
      tempUnit: "C",
      tempRangeHigh: false,
      heatMode: "Pripravený",
      setTemp: 10.0,
      deviceConfigHex: "",
      profileName: "default",
      filter2Enabled: false,
      devicePrefix: "001527FF",
      deviceSuffix: "FF3B516E"
    };

    const deviceProfiles = {
      default: {
        controls: {
          circpump: true,
          pump1: true,
          pump2: true,
          pump3: true,
          pump4: false,
          pump5: false,
          pump6: false,
          blower: true,
          light1: true,
          light2: false,
          mister: false,
          aux1: false,
          aux2: false
        }
      },

      currentSpa: {
        controls: {
          circpump: true,
          pump1: true,
          pump2: true,
          pump3: true,
          pump4: false,
          pump5: false,
          pump6: false,
          blower: true,
          light1: true,
          light2: false,
          mister: false,
          aux1: false,
          aux2: false
        }
      }
    };

    function setMessage(text) {
      document.getElementById("messageBox").textContent = text;
    }

    function updateNav(name) {
      document.getElementById("nav-home").classList.toggle("active", name === "home");
      document.getElementById("nav-controls").classList.toggle("active", name === "controls");
      document.getElementById("nav-settings").classList.toggle("active", name === "settings");
    }

    function showScreen(name) {
      document.getElementById("homeScreen").classList.remove("active");
      document.getElementById("controlsScreen").classList.remove("active");
      document.getElementById("settingsScreen").classList.remove("active");

      if (name === "home") {
        document.getElementById("homeScreen").classList.add("active");
      } else if (name === "settings") {
        document.getElementById("settingsScreen").classList.add("active");
      } else {
        document.getElementById("controlsScreen").classList.add("active");
        name = "controls";
      }

      updateNav(name);
    }

    function getCurrentDeviceId() {
      return "00000000-00000000-" + appState.devicePrefix + "-" + appState.deviceSuffix;
    }

    function getWorkerUrl(path) {
      const sep = path.includes("?") ? "&" : "?";
      return WORKER_URL + path + sep + "deviceId=" + encodeURIComponent(getCurrentDeviceId());
    }

    function setCtrlState(btnId, lblId, css, label) {
      const btn = document.getElementById(btnId);
      const lbl = document.getElementById(lblId);
      if (!btn || !lbl) return;
      btn.classList.remove("off", "on", "low", "high");
      btn.classList.add(css);
      lbl.textContent = label;
    }

    async function fetchJson(url) {
      const resp = await fetch(url, { method: "GET", cache: "no-store" });
      const text = await resp.text();
      let data = null;
      try {
        data = JSON.parse(text);
      } catch (e) {
        data = { raw: text };
      }
      return { resp, data, text };
    }

    function hexToBytes(hex) {
      if (!hex) return [];
      const clean = String(hex).replace(/[^0-9a-f]/gi, "");
      if (clean.length % 2 !== 0) return [];
      const out = [];
      for (let i = 0; i < clean.length; i += 2) {
        out.push(parseInt(clean.substring(i, i + 2), 16));
      }
      return out;
    }

    function pad2(n) {
      const v = Number(n);
      if (!Number.isFinite(v)) return "--";
      return String(v).padStart(2, "0");
    }

    function detectDeviceProfile(deviceHex) {
      const hex = (deviceHex || "").toLowerCase();
      if (!hex) return "default";
      return "currentSpa";
    }

    function applyDeviceProfile(profileName) {
      const profile = deviceProfiles[profileName] || deviceProfiles.default;
      const controls = profile.controls;

      Object.keys(controls).forEach((key) => {
        const el = document.getElementById("item-" + key);
        if (!el) return;
        el.classList.toggle("hidden", !controls[key]);
      });

      appState.profileName = profileName;
    }

    function parsePanel(hex) {
      const p = hexToBytes(hex);
      if (p.length < 25) return null;

      const tempNow = (p[6] ?? 0) / 2;
      const hour = p[7] ?? 0;
      const minute = p[8] ?? 0;
      const heatModeRaw = p[9] ?? 0;
      const flags = p[14] ?? 0;
      const rawSetTemp = p[24] ?? 0;

      const tempRangeHigh = (flags & 0x04) !== 0;
      const heatModeIsRest = (flags & 0x10) !== 0;

      let heatMode = "Pripravený";
      if (heatModeIsRest || heatModeRaw === 1) {
        heatMode = "Spiaci";
      }

      const tempRange = tempRangeHigh ? "Vysoký rozsah" : "Nízky rozsah";
      const setTemp = appState.tempUnit === "C" ? rawSetTemp / 2 : rawSetTemp;

      const byte14 = p[14] ?? 0;
      const byte15 = p[15] ?? 0;
      const byte17 = p[17] ?? 0;
      const byte18 = p[18] ?? 0;
      const byte19 = p[19] ?? 0;

      const circPumpOn = (byte14 & 0x08) !== 0 || (byte17 & 0x02) !== 0;
      const pump1On = (byte15 & 0x02) !== 0;
      const pump2On = (byte15 & 0x08) !== 0;
      const pump3On = (byte15 & 0x20) !== 0;
      const blowerOn = (byte17 & 0x04) !== 0 || (byte17 & 0x08) !== 0;
      const light1On = (byte18 & 0x03) !== 0 || (byte19 & 0x01) !== 0;

      return {
        tempNow,
        setTemp,
        time: pad2(hour) + ":" + pad2(minute),
        heatMode,
        tempRange,
        tempRangeHigh,
        circPumpOn,
        pump1On,
        pump2On,
        pump3On,
        blowerOn,
        light1On,
        rawBytes: p
      };
    }

    function parseFiltersResponse(data) {
      return data && data.parsed ? data.parsed : null;
    }

    function applyHomeState(s) {
      document.getElementById("homeTemp").textContent = Number.isFinite(s.tempNow)
        ? s.tempNow.toFixed(1) + "°C"
        : "--.-°C";

      document.getElementById("homeMode").textContent = s.heatMode || "-";
      document.getElementById("homeRange").textContent = s.tempRange || "-";
      document.getElementById("homeTime").textContent = "Čas: " + (s.time || "--:--");
      document.getElementById("homeSetTemp").textContent =
        "Nastavená teplota: " +
        (Number.isFinite(s.setTemp) ? s.setTemp.toFixed(1) + "°C" : "--.-°C");
    }

    function applyControlsState(s) {
      setCtrlState("btn-circpump", "lbl-circpump", s.circPumpOn ? "on" : "off", s.circPumpOn ? "ON" : "OFF");
      setCtrlState("btn-pump1", "lbl-pump1", s.pump1On ? "on" : "off", s.pump1On ? "ON" : "OFF");
      setCtrlState("btn-pump2", "lbl-pump2", s.pump2On ? "on" : "off", s.pump2On ? "ON" : "OFF");
      setCtrlState("btn-pump3", "lbl-pump3", s.pump3On ? "on" : "off", s.pump3On ? "ON" : "OFF");
      setCtrlState("btn-blower", "lbl-blower", s.blowerOn ? "on" : "off", s.blowerOn ? "ON" : "OFF");
      setCtrlState("btn-light1", "lbl-light1", s.light1On ? "on" : "off", s.light1On ? "ON" : "OFF");
    }

    function fillSelect(id, from, to) {
      const el = document.getElementById(id);
      if (!el) return;
      el.innerHTML = "";
      for (let i = from; i <= to; i++) {
        const opt = document.createElement("option");
        opt.value = String(i);
        opt.textContent = pad2(i);
        el.appendChild(opt);
      }
    }

    function initSelects() {
      ["timeHour","f1Hour","f2Hour"].forEach(id => fillSelect(id, 0, 23));
      ["timeMinute","f1Minute","f2Minute","f1DurMinute","f2DurMinute"].forEach(id => fillSelect(id, 0, 59));
      ["f1DurHour","f2DurHour"].forEach(id => fillSelect(id, 0, 23));
    }

    function getNum(id) {
      return Number(document.getElementById(id).value || 0);
    }

    function setNum(id, value) {
      document.getElementById(id).value = String(Number(value) || 0);
    }

    function addMinutes(h, m, dh, dm) {
      let total = (Number(h) * 60) + Number(m) + (Number(dh) * 60) + Number(dm);
      total = ((total % 1440) + 1440) % 1440;
      return {
        h: Math.floor(total / 60),
        m: total % 60
      };
    }

    function updateFilterEnds() {
      const f1 = addMinutes(getNum("f1Hour"), getNum("f1Minute"), getNum("f1DurHour"), getNum("f1DurMinute"));
      document.getElementById("f1Ends").textContent = "Koniec: " + pad2(f1.h) + ":" + pad2(f1.m);

      const f2 = addMinutes(getNum("f2Hour"), getNum("f2Minute"), getNum("f2DurHour"), getNum("f2DurMinute"));
      document.getElementById("f2Ends").textContent = "Koniec: " + pad2(f2.h) + ":" + pad2(f2.m);
    }

    function updateSliderLimits() {
      const slider = document.getElementById("tempSlider");
      const minLabel = document.getElementById("tempMinLabel");
      const maxLabel = document.getElementById("tempMaxLabel");

      if (appState.tempUnit === "C") {
        if (appState.tempRangeHigh) {
          slider.min = "26.5";
          slider.max = "40";
          slider.step = "0.5";
          minLabel.textContent = "26.5";
          maxLabel.textContent = "40";
        } else {
          slider.min = "10";
          slider.max = "26.5";
          slider.step = "0.5";
          minLabel.textContent = "10";
          maxLabel.textContent = "26.5";
        }
      } else {
        if (appState.tempRangeHigh) {
          slider.min = "80";
          slider.max = "104";
          slider.step = "1";
          minLabel.textContent = "80";
          maxLabel.textContent = "104";
        } else {
          slider.min = "50";
          slider.max = "80";
          slider.step = "1";
          minLabel.textContent = "50";
          maxLabel.textContent = "80";
        }
      }

      const current = Number(slider.value);
      const min = Number(slider.min);
      const max = Number(slider.max);

      if (current < min) slider.value = String(min);
      if (current > max) slider.value = String(max);

      appState.setTemp = Number(slider.value);
    }

    function updateSettingsUI() {
      document.getElementById("settingsTempValue").textContent =
        Number(appState.setTemp).toFixed(appState.tempUnit === "C" ? 1 : 0) + "°" + appState.tempUnit;

      const slider = document.getElementById("tempSlider");
      slider.value = String(appState.setTemp);

      document.getElementById("unitCBtn").classList.toggle("active", appState.tempUnit === "C");
      document.getElementById("unitFBtn").classList.toggle("active", appState.tempUnit === "F");

      const isReady = appState.heatMode === "Pripravený";
      document.getElementById("heatReadyBtn").classList.toggle("active", isReady);
      document.getElementById("heatRestBtn").classList.toggle("active", !isReady);

      document.getElementById("rangeLowBtn").classList.toggle("active", !appState.tempRangeHigh);
      document.getElementById("rangeHighBtn").classList.toggle("active", appState.tempRangeHigh);

      document.getElementById("btnF2Off").classList.toggle("active", !appState.filter2Enabled);
      document.getElementById("btnF2On").classList.toggle("active", appState.filter2Enabled);

      document.getElementById("tempRangeText").textContent =
        appState.tempRangeHigh ? "Vysoký rozsah" : "Nízky rozsah";

      updateSliderLimits();
      updateFilterEnds();
    }

    async function loadDeviceConfig() {
      try {
        const { resp, data } = await fetchJson(getWorkerUrl("/deviceconfig"));
        if (!resp.ok) {
          applyDeviceProfile("default");
          return;
        }

        const hex = data && data.hex ? data.hex : "";
        appState.deviceConfigHex = hex;
        const profile = detectDeviceProfile(hex);
        applyDeviceProfile(profile);
      } catch (e) {
        applyDeviceProfile("default");
      }
    }

    async function loadPanelUpdate() {
      try {
        const { resp, data, text } = await fetchJson(getWorkerUrl("/panelupdate"));

        if (!resp.ok) {
          setMessage("Načítanie stavu zlyhalo. HTTP status: " + resp.status);
          return;
        }

        const hex = data && data.hex ? data.hex : "";
        const parsed = parsePanel(hex);

        if (!parsed) {
          setMessage("Nepodarilo sa rozpoznať stav z PanelUpdate.");
          console.log("panelupdate raw:", text);
          return;
        }

        appState.heatMode = parsed.heatMode || "Pripravený";
        appState.tempRangeHigh = !!parsed.tempRangeHigh;
        appState.setTemp = Number.isFinite(parsed.setTemp) ? parsed.setTemp : appState.setTemp;

        setNum("timeHour", Number(parsed.time.split(":")[0]));
        setNum("timeMinute", Number(parsed.time.split(":")[1]));

        applyHomeState(parsed);
        applyControlsState(parsed);
        updateSettingsUI();
        setMessage("Stav vírivky bol aktualizovaný.");
      } catch (e) {
        setMessage("Chyba pri načítaní stavu: " + e.message);
      }
    }

    async function sendButton(code, name) {
      try {
        setMessage("Odosielam príkaz: " + name + " ...");
        const { resp, data } = await fetchJson(getWorkerUrl("/button?code=" + encodeURIComponent(code)));

        if (!resp.ok) {
          setMessage("Príkaz zlyhal: " + name + ". HTTP status: " + resp.status);
          return;
        }

        const txt = (data && data.response) ? data.response : "";
        const ok = txt.includes("Command received") || txt.includes('status="0"');

        setMessage((ok ? "Príkaz prijatý: " : "Príkaz odoslaný: ") + name + ". Aktualizujem stav...");
        setTimeout(loadPanelUpdate, 1500);
      } catch (e) {
        setMessage("Chyba pri odoslaní príkazu " + name + ": " + e.message);
      }
    }

    function convertSetTempForWorker(temp, unit) {
      if (unit === "C") {
        return String((Number(temp) * 2).toFixed(1));
      }
      return String(Number(temp).toFixed(1));
    }

    async function saveSetTemp() {
      try {
        const uiValue = Number(document.getElementById("tempSlider").value);
        const workerValue = convertSetTempForWorker(uiValue, appState.tempUnit);

        setMessage("Nastavujem teplotu na " + uiValue.toFixed(appState.tempUnit === "C" ? 1 : 0) + "°" + appState.tempUnit + " ...");

        const { resp, data } = await fetchJson(getWorkerUrl("/settemp?value=" + encodeURIComponent(workerValue)));

        if (!resp.ok) {
          setMessage("Nastavenie teploty zlyhalo. HTTP status: " + resp.status);
          return;
        }

        const txt = (data && data.response) ? data.response : "";
        const ok = txt.includes("Command received") || txt.includes('status="0"');

        appState.setTemp = uiValue;
        updateSettingsUI();

        setMessage((ok ? "Teplota nastavená. " : "Príkaz odoslaný. ") + "Čakám na server...");
        setTimeout(loadPanelUpdate, 2500);
        setTimeout(loadPanelUpdate, 6000);
      } catch (e) {
        setMessage("Chyba pri nastavení teploty: " + e.message);
      }
    }

    async function setTempUnits(unit) {
      try {
        setMessage("Prepínam jednotky na °" + unit + " ...");
        const { resp, data } = await fetchJson(getWorkerUrl("/tempunits?value=" + encodeURIComponent(unit)));

        if (!resp.ok) {
          setMessage("Prepnutie jednotiek zlyhalo. HTTP status: " + resp.status);
          return;
        }

        appState.tempUnit = unit;
        updateSettingsUI();

        const txt = (data && data.response) ? data.response : "";
        const ok = txt.includes("Command received") || txt.includes('status="0"');

        setMessage((ok ? "Jednotky zmenené. " : "Príkaz odoslaný. ") + "Aktualizujem stav...");
        setTimeout(loadPanelUpdate, 1500);
      } catch (e) {
        setMessage("Chyba pri prepnutí jednotiek: " + e.message);
      }
    }

    async function sendToggleButton(code, successText, errorText, delay = 1500) {
      const { resp, data } = await fetchJson(
        getWorkerUrl("/button?code=" + encodeURIComponent(code))
      );

      if (!resp.ok) {
        setMessage(errorText + " HTTP status: " + resp.status);
        return false;
      }

      const txt = data.response || "";
      const ok = txt.includes("Command received") || txt.includes('status="0"');

      setMessage((ok ? successText : "Príkaz odoslaný.") + " Aktualizujem stav...");
      setTimeout(loadPanelUpdate, delay);
      return true;
    }

    async function setHeatMode(target) {
      try {
        const currentlyReady = appState.heatMode === "Pripravený";
        const wantReady = target === "ready";

        if ((wantReady && currentlyReady) || (!wantReady && !currentlyReady)) {
          setMessage("Teplotný režim je už nastavený.");
          return;
        }

        setMessage("Prepínam teplotný režim...");
        await sendToggleButton(81, "Teplotný režim prepnutý.", "Prepnutie teplotného režimu zlyhalo.", 2500);
      } catch (e) {
        setMessage("Chyba pri prepínaní teplotného režimu: " + e.message);
      }
    }

    async function setTempRange(target) {
      try {
        const wantHigh = target === "high";

        if ((wantHigh && appState.tempRangeHigh) || (!wantHigh && !appState.tempRangeHigh)) {
          setMessage("Teplotný rozsah je už nastavený.");
          return;
        }

        setMessage("Prepínam teplotný rozsah...");
        await sendToggleButton(80, "Teplotný rozsah prepnutý.", "Prepnutie teplotného rozsahu zlyhalo.", 2000);
      } catch (e) {
        setMessage("Chyba pri prepínaní teplotného rozsahu: " + e.message);
      }
    }

    async function saveSystemTime() {
      try {
        const hh = getNum("timeHour");
        const mm = getNum("timeMinute");

        setMessage("Ukladám čas panelu...");

        const { resp, data } = await fetchJson(
          getWorkerUrl("/systemtime?hh=" + encodeURIComponent(hh) + "&mm=" + encodeURIComponent(mm))
        );

        if (!resp.ok) {
          setMessage("Uloženie času zlyhalo. HTTP status: " + resp.status);
          return;
        }

        const txt = data.response || "";
        const ok = txt.includes("Command received") || txt.includes('status="0"');

        setMessage((ok ? "Čas uložený." : "Príkaz odoslaný.") + " Aktualizujem stav...");
        setTimeout(loadPanelUpdate, 2000);
      } catch (e) {
        setMessage("Chyba pri ukladaní času: " + e.message);
      }
    }

    function setFilter2Enabled(enabled) {
      appState.filter2Enabled = !!enabled;
      updateSettingsUI();
    }

    async function loadFilters() {
      try {
        setMessage("Načítavam filtre...");
        const { resp, data } = await fetchJson(getWorkerUrl("/getfilters"));

        if (!resp.ok) {
          setMessage("Načítanie filtrov zlyhalo. HTTP status: " + resp.status);
          return;
        }

        const p = parseFiltersResponse(data);
        if (!p) {
          setMessage("Filtre sa nepodarilo rozpoznať.");
          return;
        }

        setNum("f1Hour", p.filterCycle1.startsAtHour);
        setNum("f1Minute", p.filterCycle1.startsAtMinute);
        setNum("f1DurHour", p.filterCycle1.durationHour);
        setNum("f1DurMinute", p.filterCycle1.durationMinute);

        appState.filter2Enabled = !!p.filterCycle2.enabled;
        setNum("f2Hour", p.filterCycle2.startsAtHour);
        setNum("f2Minute", p.filterCycle2.startsAtMinute);
        setNum("f2DurHour", p.filterCycle2.durationHour);
        setNum("f2DurMinute", p.filterCycle2.durationMinute);

        document.getElementById("filtersInfo").textContent =
          "Cyklus 1: " + pad2(p.filterCycle1.startsAtHour) + ":" + pad2(p.filterCycle1.startsAtMinute) +
          ", trvanie " + p.filterCycle1.durationHour + "h " + p.filterCycle1.durationMinute + "m\n" +
          "Cyklus 2: " + (p.filterCycle2.enabled ? "Zapnutý" : "Vypnutý") + ", " +
          pad2(p.filterCycle2.startsAtHour) + ":" + pad2(p.filterCycle2.startsAtMinute) +
          ", trvanie " + p.filterCycle2.durationHour + "h " + p.filterCycle2.durationMinute + "m";

        updateSettingsUI();
        setMessage("Filtre načítané.");
      } catch (e) {
        setMessage("Chyba pri načítaní filtrov: " + e.message);
      }
    }

    async function saveFilters() {
      try {
        const params = new URLSearchParams({
          f1h: String(getNum("f1Hour")),
          f1m: String(getNum("f1Minute")),
          f1dh: String(getNum("f1DurHour")),
          f1dm: String(getNum("f1DurMinute")),
          f2en: appState.filter2Enabled ? "1" : "0",
          f2h: String(getNum("f2Hour")),
          f2m: String(getNum("f2Minute")),
          f2dh: String(getNum("f2DurHour")),
          f2dm: String(getNum("f2DurMinute"))
        });

        setMessage("Ukladám filtračné cykly...");
        const { resp, data } = await fetchJson(getWorkerUrl("/filters?" + params.toString()));

        if (!resp.ok) {
          setMessage("Uloženie filtrov zlyhalo. HTTP status: " + resp.status);
          return;
        }

        const txt = data.response || "";
        const ok = txt.includes("Command received") || txt.includes('status="0"');

        setMessage((ok ? "Filtračné cykly uložené." : "Príkaz odoslaný.") + " Čakám na server...");
        setTimeout(loadFilters, 2500);
        setTimeout(loadFilters, 6000);
      } catch (e) {
        setMessage("Chyba pri ukladaní filtrov: " + e.message);
      }
    }

    async function refreshAll() {
      await loadDeviceConfig();
      await loadPanelUpdate();
      await loadFilters();
    }

    document.getElementById("tempSlider").addEventListener("input", function () {
      const val = Number(this.value);
      appState.setTemp = val;
      document.getElementById("settingsTempValue").textContent =
        val.toFixed(appState.tempUnit === "C" ? 1 : 0) + "°" + appState.tempUnit;
    });

    [
      "f1Hour","f1Minute","f1DurHour","f1DurMinute",
      "f2Hour","f2Minute","f2DurHour","f2DurMinute"
    ].forEach(id => {
      document.getElementById(id).addEventListener("change", updateFilterEnds);
    });

    initSelects();
    updateSettingsUI();
    showScreen("home");
    refreshAll();
    setInterval(loadPanelUpdate, 15000);
  </script>
</body>
</html>
