<!DOCTYPE html>
<html lang="sk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Platinum Lech Spa</title>
  <link rel="icon" type="image/svg+xml" href='data:image/svg+xml;utf8,
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192">
  <defs>
    <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="%2308162b"/>
      <stop offset="100%" stop-color="%2311b4ff"/>
    </linearGradient>
  </defs>
  <rect width="192" height="192" rx="40" fill="url(%23g)"/>
  <text x="96" y="112" text-anchor="middle" font-size="78" font-family="Arial" font-weight="700" fill="white">SPA</text>
</svg>'>
  <meta name="theme-color" content="#08162b">

  <style>
    :root{
      --bg-1:#050b14;
      --bg-2:#09182a;
      --bg-3:#0d2440;
      --card:#091524;
      --card-2:rgba(12, 29, 49, 0.84);
      --line:rgba(136, 212, 255, 0.16);
      --line-strong:rgba(136, 212, 255, 0.28);
      --text:#f5fbff;
      --muted:#97b3c9;
      --muted-2:#cfe6f7;
      --accent:#58cbff;
      --accent-2:#7cf2ff;
      --accent-soft:rgba(88,203,255,.16);
      --ok:#57f0b3;
      --danger:#ff7f7f;
      --shadow:0 20px 60px rgba(0,0,0,.45);
      --shadow-soft:0 10px 30px rgba(0,0,0,.28);
      --radius-xl:28px;
      --radius-lg:22px;
      --radius-md:16px;
      --radius-sm:12px;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      min-height: 100%;
      font-family: Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top, rgba(49,129,255,.18), transparent 30%),
        radial-gradient(circle at 80% 20%, rgba(88,203,255,.14), transparent 24%),
        linear-gradient(180deg, var(--bg-2) 0%, var(--bg-1) 100%);
    }

    body::before,
    body::after{
      content:"";
      position: fixed;
      inset: 0;
      pointer-events:none;
      z-index:0;
    }

    body::before{
      background:
        radial-gradient(circle at 12% 18%, rgba(124,242,255,.08) 0 2px, transparent 3px),
        radial-gradient(circle at 78% 30%, rgba(124,242,255,.06) 0 1.5px, transparent 3px),
        radial-gradient(circle at 30% 72%, rgba(255,255,255,.05) 0 2px, transparent 3px),
        radial-gradient(circle at 64% 82%, rgba(124,242,255,.05) 0 1px, transparent 2px);
      background-size: 180px 180px, 220px 220px, 160px 160px, 200px 200px;
      opacity: .9;
    }

    body::after{
      backdrop-filter: blur(0.5px);
    }

    .app {
      max-width: 430px;
      margin: 0 auto;
      min-height: 100vh;
      position: relative;
      z-index: 1;
      overflow: hidden;
      padding: 14px 14px 28px;
    }

    .bubble-bg::before,
    .bubble-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: .18;
      background-image:
        radial-gradient(circle at 18px 18px, rgba(255,255,255,.16) 0 2px, transparent 2.6px),
        radial-gradient(circle at 48px 40px, rgba(124,242,255,.12) 0 1.7px, transparent 2.2px),
        radial-gradient(circle at 88px 18px, rgba(255,255,255,.08) 0 1.2px, transparent 1.8px);
      background-size: 120px 120px;
      z-index: 0;
    }

    .topbar {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 4px 2px 8px;
      position: relative;
      z-index: 2;
    }

    .brandbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding: 4px 4px 0;
    }

    .brand-title{
      display:flex;
      flex-direction:column;
      gap:2px;
    }

    .brand-title strong{
      font-size: 14px;
      letter-spacing: 1.8px;
      color: rgba(255,255,255,.95);
      font-weight: 700;
    }

    .brand-title span{
      font-size: 11px;
      letter-spacing: 4px;
      color: var(--muted);
      text-transform: uppercase;
    }

    .status-chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(9, 23, 39, 0.76);
      color: var(--muted-2);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.04);
      font-size: 13px;
      backdrop-filter: blur(10px);
      white-space: nowrap;
    }

    .status-dot{
      width:8px;
      height:8px;
      border-radius:50%;
      background: var(--ok);
      box-shadow: 0 0 12px rgba(87,240,179,.75);
      flex:0 0 auto;
    }

    .nav-wrap{
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap:10px;
      padding: 2px;
      background: rgba(8, 20, 35, 0.64);
      border: 1px solid rgba(136, 212, 255, 0.12);
      border-radius: 18px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.03);
      backdrop-filter: blur(12px);
    }

    .nav-btn {
      min-width: 0;
      height: 48px;
      border: 1px solid transparent;
      border-radius: 14px;
      background: transparent;
      color: var(--muted-2);
      font-size: 15px;
      font-weight: 700;
      letter-spacing: .1px;
      cursor: pointer;
      transition: .2s ease;
    }

    .nav-btn.active {
      color: #ffffff;
      background:
        linear-gradient(180deg, rgba(105,220,255,.28), rgba(33,91,132,.28));
      border-color: rgba(136, 212, 255, 0.18);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.08),
        0 8px 24px rgba(44, 173, 255, 0.16);
    }

    .screen {
      display: none;
      position: relative;
      z-index: 1;
    }

    .screen.active {
      display: block;
    }

    .panel {
      width: 100%;
      margin: 14px auto 0;
      border-radius: var(--radius-xl);
      padding: 18px;
      position: relative;
      background:
        linear-gradient(180deg, rgba(12, 27, 46, 0.92), rgba(7, 16, 28, 0.96));
      border: 1px solid var(--line);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.05),
        inset 0 0 0 1px rgba(255,255,255,.02),
        var(--shadow);
      overflow: hidden;
      backdrop-filter: blur(14px);
    }

    .panel::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at top center, rgba(88,203,255,.12), transparent 28%),
        linear-gradient(180deg, rgba(255,255,255,.02), transparent 16%);
      pointer-events:none;
    }

    .page-head{
      position:relative;
      z-index:1;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-bottom: 14px;
    }

    .page-title{
      font-size: 24px;
      font-weight: 700;
      color: #fff;
      letter-spacing: .2px;
      margin: 0;
    }

    .page-sub{
      font-size: 13px;
      color: var(--muted);
      margin-top: 4px;
    }

    .ghost-chip{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:34px;
      padding:0 12px;
      border-radius:999px;
      border:1px solid var(--line);
      color: var(--muted-2);
      background: rgba(255,255,255,.03);
      font-size:13px;
      white-space: nowrap;
    }

    .hero-card{
      position:relative;
      z-index:1;
      border-radius: 26px;
      padding: 22px 18px 20px;
      margin-top: 8px;
      background:
        radial-gradient(circle at 50% 0%, rgba(88,203,255,.10), transparent 40%),
        linear-gradient(180deg, rgba(9, 23, 40, 0.92), rgba(8, 18, 32, 0.9));
      border: 1px solid rgba(136, 212, 255, 0.14);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.04),
        0 20px 40px rgba(0,0,0,.22);
    }

    .temp-ring-wrap{
      position:relative;
      width: 240px;
      height: 240px;
      margin: 16px auto 6px;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .temp-ring{
      position:absolute;
      inset:0;
      border-radius:50%;
      background:
        radial-gradient(circle at center, rgba(10,21,35,.2) 0 50%, transparent 51%),
        conic-gradient(from 210deg, rgba(88,203,255,.18), rgba(124,242,255,.78), rgba(88,203,255,.18));
      filter: drop-shadow(0 0 18px rgba(88,203,255,.16));
      mask: radial-gradient(circle, transparent 0 58%, #000 61%);
      -webkit-mask: radial-gradient(circle, transparent 0 58%, #000 61%);
      opacity:.95;
    }

    .temp-ring::after{
      content:"";
      position:absolute;
      inset:16px;
      border-radius:50%;
      border:1px solid rgba(136, 212, 255, 0.10);
    }

    .temp-core{
      position:relative;
      z-index:1;
      width: 182px;
      height: 182px;
      border-radius:50%;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      text-align:center;
      background:
        radial-gradient(circle at top, rgba(88,203,255,.14), transparent 34%),
        linear-gradient(180deg, rgba(12, 31, 52, 0.96), rgba(7, 18, 30, 0.98));
      border:1px solid rgba(136, 212, 255, 0.14);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.06),
        inset 0 -14px 30px rgba(0,0,0,.22),
        0 12px 34px rgba(0,0,0,.28);
    }

    .temp-caption{
      font-size:12px;
      text-transform:uppercase;
      letter-spacing:2px;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .home-temp {
      text-align: center;
      font-size: 58px;
      font-weight: 800;
      letter-spacing: -1px;
      line-height: 1;
      margin: 0;
      color:#ffffff;
      text-shadow: 0 0 22px rgba(88,203,255,.18);
    }

    .swirl {
      text-align: center;
      font-size: 34px;
      opacity: .95;
      line-height: 1;
      margin: 10px 0 0;
      filter: drop-shadow(0 0 8px rgba(88,203,255,.22));
    }

    .home-mode {
      text-align: center;
      font-size: 28px;
      font-weight: 700;
      margin-top: 16px;
      letter-spacing: .2px;
    }

    .home-range {
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height: 34px;
      padding: 0 14px;
      border-radius: 999px;
      border: 1px solid rgba(136, 212, 255, 0.14);
      background: rgba(88,203,255,.08);
      font-size: 14px;
      color: #eaf8ff;
      margin: 14px auto 0;
    }

    .home-badges{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 18px;
    }

    .info-badge{
      border-radius: 18px;
      background: rgba(255,255,255,.04);
      border:1px solid rgba(136, 212, 255, 0.12);
      padding: 12px 12px 11px;
      min-height: 74px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.03);
    }

    .info-badge-label{
      font-size:12px;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .info-badge-value{
      font-size:18px;
      color:#fff;
      font-weight:700;
      line-height:1.2;
      word-break: break-word;
    }

    .quick-actions{
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 16px;
    }

    .quick-btn{
      min-height: 50px;
      border-radius: 16px;
      border:1px solid rgba(136, 212, 255, 0.12);
      background: rgba(255,255,255,.04);
      color:#fff;
      font-size:14px;
      font-weight:700;
      cursor:pointer;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.04);
    }

    .section-title{
      margin: 4px 0 14px;
      font-size: 22px;
      font-weight: 700;
      color: #fff;
      text-align: center;
      position:relative;
      z-index:1;
    }

    .controls-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      justify-items: stretch;
      align-items: stretch;
      position: relative;
      z-index: 1;
    }

    .control-item {
      width: 100%;
      text-align: center;
      border-radius: 22px;
      padding: 14px 8px 12px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02));
      border: 1px solid rgba(136, 212, 255, 0.12);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.03),
        0 8px 24px rgba(0,0,0,.16);
    }

    .circle-btn {
      width: 74px;
      height: 74px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,.08);
      cursor: pointer;
      margin: 0 auto 10px;
      color: #d7e8ff;
      font-size: 28px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      background:
        radial-gradient(circle at 35% 28%, rgba(255,255,255,.18), transparent 24%),
        linear-gradient(180deg, #182536 0%, #0a121d 60%, #05090f 100%);
      box-shadow:
        inset 0 10px 18px rgba(255,255,255,.06),
        inset 0 -10px 18px rgba(0,0,0,.38),
        0 8px 20px rgba(0,0,0,.22);
      transition: transform .15s ease, box-shadow .2s ease;
    }

    .circle-btn:active{
      transform: scale(.97);
    }

    .circle-btn.off {
      opacity: .92;
    }

    .circle-btn.on,
    .circle-btn.low,
    .circle-btn.high {
      background:
        radial-gradient(circle at 35% 28%, rgba(255,255,255,.28), transparent 24%),
        linear-gradient(180deg, #163549 0%, #0c1f2c 50%, #08131c 100%);
      box-shadow:
        inset 0 0 24px rgba(88,203,255,.22),
        0 0 0 1px rgba(124,242,255,.08),
        0 0 20px rgba(88,203,255,.28),
        0 0 42px rgba(88,203,255,.18);
      color: #ffffff;
    }

    .circle-btn.light.on {
      box-shadow:
        inset 0 0 26px rgba(124,242,255,.22),
        0 0 0 1px rgba(124,242,255,.08),
        0 0 22px rgba(124,242,255,.30),
        0 0 44px rgba(124,242,255,.18);
      color: #ffffff;
    }

    .control-label {
      font-size: 15px;
      line-height: 1.2;
      color: #f2f7ff;
      min-height: 36px;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .control-state {
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width: 58px;
      min-height: 28px;
      padding: 0 10px;
      border-radius: 999px;
      font-size: 12px;
      color: #ffffff;
      margin-top: 4px;
      font-weight: 700;
      border: 1px solid rgba(136, 212, 255, 0.08);
      background: rgba(255,255,255,.04);
      text-shadow: none;
    }

    .settings-stack{
      position:relative;
      z-index:1;
    }

    .settings-block {
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(136, 212, 255, 0.12);
      border-radius: 22px;
      padding: 16px;
      margin-bottom: 14px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.03);
    }

    .settings-label {
      font-size: 16px;
      margin-bottom: 10px;
      color: #ffffff;
      font-weight: 700;
    }

    .settings-value {
      font-size: 22px;
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 12px;
      letter-spacing: -.2px;
    }

    .small {
      font-size: 13px;
      color: var(--muted-2);
      white-space: pre-wrap;
      word-break: break-word;
      line-height: 1.5;
    }

    .slider-row {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .slider-min,
    .slider-max {
      width: 44px;
      text-align: center;
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
    }

    input[type="range"] {
      flex: 1;
      accent-color: var(--accent);
    }

    .settings-btn,
    .settings-btn-small,
    .settings-btn-wide,
    .settings-select {
      border: 1px solid rgba(136, 212, 255, 0.14);
      border-radius: 16px;
      color: #eef7ff;
      background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
      box-shadow: inset 0 1px 0 rgba(255,255,255,.04);
    }

    .settings-btn {
      min-height: 48px;
      padding: 10px 14px;
      font-size: 15px;
      font-weight: 700;
      width: 100%;
      cursor: pointer;
    }

    .settings-btn-small {
      min-width: 70px;
      min-height: 46px;
      padding: 8px 12px;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
    }

    .settings-btn-wide {
      width: 100%;
      min-height: 50px;
      padding: 10px 14px;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
    }

    .settings-select {
      width: 100%;
      min-height: 48px;
      padding: 10px 12px;
      font-size: 16px;
      font-weight: 700;
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
      color:#ffffff;
    }

    .settings-select option {
      color: #000;
    }

    .settings-btn.active,
    .settings-btn-small.active,
    .settings-btn-wide.active {
      background: linear-gradient(180deg, rgba(88,203,255,.22), rgba(20,88,132,.22));
      box-shadow:
        inset 0 0 16px rgba(88,203,255,.14),
        0 0 18px rgba(88,203,255,.10);
      border-color: rgba(88,203,255,.28);
      color: #ffffff;
    }

    .btn-grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .logo-wrap {
      text-align: center;
      margin-top: 28px;
      color: rgba(255,255,255,.96);
      position:relative;
      z-index:1;
    }

    .logo-main {
      font-size: 36px;
      letter-spacing: 2px;
      font-weight: 300;
      line-height: 1.05;
      opacity:.96;
    }

    .logo-sub {
      font-size: 14px;
      letter-spacing: 10px;
      margin-top: 8px;
      text-transform: lowercase;
      color: var(--muted);
    }

    .message-box {
      width: 100%;
      margin: 14px auto 0;
      background: rgba(8, 18, 31, 0.78);
      border: 1px solid rgba(136, 212, 255, 0.12);
      color: #e8f3ff;
      border-radius: 18px;
      padding: 14px 14px;
      font-size: 14px;
      min-height: 52px;
      white-space: pre-wrap;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.03);
      position:relative;
      z-index:1;
    }

    .hidden {
      display: none !important;
    }

    @media (max-width: 380px){
      .home-temp{ font-size: 48px; }
      .temp-ring-wrap{ width: 220px; height:220px; }
      .temp-core{ width: 170px; height:170px; }
      .circle-btn{ width: 68px; height: 68px; font-size:26px; }
      .control-label{ font-size:14px; }
      .logo-main{ font-size: 32px; }
    }
  </style>
</head>
<body>
  <div class="app bubble-bg">
    <div class="topbar">
      <div class="brandbar">
        <div class="brand-title">
          <strong>PLATINUM LECH</strong>
          <span>spa</span>
        </div>
        <div class="status-chip">
          <span class="status-dot"></span>
          <span>Cloud pripojený</span>
        </div>
      </div>

      <div class="nav-wrap">
        <button class="nav-btn active" id="nav-home" onclick="showScreen('home')">Domov</button>
        <button class="nav-btn" id="nav-controls" onclick="showScreen('controls')">Ovládanie</button>
        <button class="nav-btn" id="nav-settings" onclick="showScreen('settings')">Nastavenia</button>
      </div>
    </div>

    <div id="homeScreen" class="screen active">
      <div class="panel">
        <div class="page-head">
          <div>
            <h1 class="page-title">Domov</h1>
            <div class="page-sub">Prehľad stavu vírivky</div>
          </div>
          <div class="ghost-chip" id="homeCloudChip">☁ Online</div>
        </div>

        <div class="hero-card">
          <div class="temp-ring-wrap">
            <div class="temp-ring"></div>
            <div class="temp-core">
              <div class="temp-caption">Aktuálna teplota</div>
              <div class="home-temp" id="homeTemp">--.-°C</div>
              <div class="swirl">🌀</div>
            </div>
          </div>

          <div class="home-mode" id="homeMode">Pripravený</div>
          <div class="home-range" id="homeRange">Nízky rozsah</div>

          <div class="home-badges">
            <div class="info-badge">
              <div class="info-badge-label">Čas panelu</div>
              <div class="info-badge-value" id="homeTime">Čas: --:--</div>
            </div>
            <div class="info-badge">
              <div class="info-badge-label">Nastavená teplota</div>
              <div class="info-badge-value" id="homeSetTemp">Nastavená teplota: --.-°C</div>
            </div>
          </div>

          <div class="quick-actions">
            <button class="quick-btn" onclick="showScreen('controls')">Ovládanie</button>
            <button class="quick-btn" onclick="showScreen('settings')">Nastavenia</button>
            <button class="quick-btn" onclick="refreshAll()">Obnoviť</button>
          </div>
        </div>

        <div class="logo-wrap" style="margin-top:24px;">
          <div class="logo-main">PLATINUM LECH</div>
          <div class="logo-sub">SPA</div>
        </div>
      </div>
    </div>

    <div id="controlsScreen" class="screen">
      <div class="panel">
        <div class="page-head">
          <div>
            <h2 class="page-title">Ovládanie</h2>
            <div class="page-sub">Rýchle prepínanie funkcií</div>
          </div>
          <div class="ghost-chip">Smart control</div>
        </div>

